# Copy this file to turnserver.conf and fill in the variables.
# Replace ${TURN_HOST} and ${TURN_SHARED_SECRET} with real values.

listening-port=3478
tls-listening-port=5349

# HMAC-based short-term credential mechanism
use-auth-secret
static-auth-secret=${TURN_SHARED_SECRET}
realm=${TURN_HOST}

# Protect the relay from abuse
total-quota=100
bps-capacity=0
stale-nonce=600

no-multicast-peers
