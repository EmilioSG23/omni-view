# OmniView backend example environment
# Port the server listens on
PORT=3000
# Environment (dev, production, etc.) — used for conditional logic in code
NODE_ENV=dev
# Path to the sqlite database file
DB_PATH=omniview.db
# URL for database connection (for ORMs that support it, e.g. Sequelize)
DB_URL=sqlite:omniview.db
# Point and comma - separated list of allowed origins for CORS and middleware
# Examples: http://localhost:3000;https://example.com
ALLOWED_ORIGINS=http://localhost:3000

# Optional: Directory where captured frames are stored as files (not recommended for production)
# Layout: <FRAME_STORE_PATH>/<agent-id>/YYYY-MM-DD/<timestamp>_<seq>.jpg
FRAME_STORE_PATH=<directory_path>

# Persistence controls (default: no persistence — stream-only)
# Set to true to persist frames globally (not recommended for long-term storage)
PERSIST_FRAMES=<true|false>