{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"module": "Node16",
		"moduleResolution": "Node16",
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true,
		"allowSyntheticDefaultImports": true,
		"target": "ES2022",
		"outDir": "./dist",
		"rootDir": "./src"
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
